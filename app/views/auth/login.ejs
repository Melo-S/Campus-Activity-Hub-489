<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Login — Campus Activity Hub</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/assets/css/styles.css" rel="stylesheet">
</head>
<body>

<nav class="navbar navbar-expand-lg bg-white border-bottom">
  <div class="container">
    <a class="navbar-brand" href="/">Campus Activity Hub</a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarsExample"
      aria-controls="navbarsExample" aria-expanded="false" aria-label="Toggle navigation">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="navbarsExample">
      <ul class="navbar-nav me-auto mb-2 mb-lg-0">
        <li class="nav-item"><a class="nav-link" href="/#students">Students</a></li>
        <li class="nav-item"><a class="nav-link" href="/#organizers">Organizer Portal</a></li>
        <li class="nav-item"><a class="nav-link" href="/#admin">Admin</a></li>
        <li class="nav-item"><a class="nav-link" href="/#mapping">Use Case Mapping</a></li>
      </ul>
      <div class="d-flex gap-2">
        <a class="btn btn-outline-primary btn-sm" href="/login">Login</a>
        <a class="btn btn-primary btn-sm" href="/signup">Sign Up</a>
      </div>
    </div>
  </div>
</nav>

<main class="container my-4">
  <div class="d-flex justify-content-between align-items-start flex-wrap gap-2 mb-3">
    <div>
      <div class="pill mb-2">Student / Organizer / Admin</div>
      <h1 class="h3 mb-1">Login</h1>
      <div class="text-muted">Authenticate and route to the correct home page by role.</div>
    </div>
    <div class="text-end">
      <span class="badge bg-primary">Live</span>
    </div>
  </div>

  <div class="mb-3">
    <div class="fw-semibold mb-1">Use cases covered</div>
    <div class="d-flex flex-wrap gap-1">
      <span class="badge bg-info text-dark me-1 mb-1">UC-S02</span>
    </div>
  </div>

  <% if (error) { %>
    <div class="alert alert-danger"><%= error %></div>
  <% } %>

  <div class="form-section">
    <h5 class="section-heading">Form</h5>

    <form method="POST" action="/login">
      <div class="mb-3">
        <label class="form-label" for="email">Email address</label>
        <input id="email" name="email" type="email" class="form-control" placeholder="Email address" required>
      </div>

      <div class="mb-3">
        <label class="form-label" for="password">Password</label>
        <input id="password" name="password" type="password" class="form-control" placeholder="Password" required>
      </div>

      <!-- ✅ Demo role selector (temporary, for testing redirects) -->
      <div class="mb-3">
        <label class="form-label" for="role">Role (demo only)</label>
        <select id="role" name="role" class="form-select">
          <option value="student" selected>student</option>
          <option value="organizer">organizer</option>
          <option value="admin">admin</option>
        </select>
        <div class="form-text">Temporary dropdown to test role-based redirects before DB is connected.</div>
      </div>

      <button class="btn btn-primary" type="submit">Submit</button>
      <a class="btn btn-outline-secondary ms-2" href="/signup">Go to Sign Up</a>
    </form>
  </div>

  <div class="mb-3 mt-4">
    <div class="fw-semibold mb-1">Primary Actions</div>
    <div class="d-flex flex-wrap gap-1">
      <span class="badge badge-soft me-1 mb-1">Submit login</span>
      <span class="badge badge-soft me-1 mb-1">Forgot password (optional)</span>
      <span class="badge badge-soft me-1 mb-1">Go to Register</span>
    </div>
  </div>

  <footer class="footer text-center">Campus Activity Hub — Project Build</footer>
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Campus Activity Hub</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

<nav class="navbar navbar-expand-lg bg-white border-bottom">
  <div class="container">
    <a class="navbar-brand" href="/">Campus Activity Hub</a>
    <div class="ms-auto d-flex gap-2">
      <a class="btn btn-outline-primary btn-sm" href="/login">Login</a>
      <a class="btn btn-primary btn-sm" href="/signup">Sign Up</a>
    </div>
  </div>
</nav>

<header class="container py-5">
  <div class="row g-4 align-items-center">
    <div class="col-12 col-lg-7">
      <div class="badge text-bg-light border mb-2">CPTS 489 — Project</div>
      <h1 class="display-6 fw-semibold mb-2">Campus Activity Hub</h1>
      <p class="lead text-muted mb-3">
        Check campus busyness (Library / Rec / Dining) and create quick activities (study, workout, dinner) to invite friends and track RSVPs.
      </p>
      <div class="d-flex flex-wrap gap-2">
        <a class="btn btn-primary" href="/login">Log in to continue</a>
        <a class="btn btn-outline-primary" href="/signup">Create an account</a>
      </div>
      <div class="text-muted small mt-3">
        Note: Live data comes from student crowd updates (auto-expiring) and verified organizer/staff updates.
      </div>
    </div>

    <div class="col-12 col-lg-5">
      <div class="card shadow-sm">
        <div class="card-body">
          <div class="fw-semibold mb-2">What you can do</div>
          <ul class="text-muted mb-0">
            <li>See “Happening Now” busy levels</li>
            <li>Post crowd updates + confirm/disagree</li>
            <li>Create activities + RSVP + invite friends</li>
            <li>Report content when needed</li>
          </ul>
        </div>
      </div>
    </div>
  </div>
</header>

</body>
</html>
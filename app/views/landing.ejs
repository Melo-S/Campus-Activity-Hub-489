<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Campus Activity Hub</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/assets/css/styles.css" rel="stylesheet">
</head>
<body>

<nav class="navbar navbar-dark">
  <div class="container">
    <a class="navbar-brand" href="/">Campus Activity Hub</a>
    <div class="d-flex gap-2">
      <a class="btn btn-outline-primary btn-sm" href="/login">Login</a>
      <a class="btn btn-primary btn-sm" href="/signup">Sign Up</a>
    </div>
  </div>
</nav>

<div class="container py-5">
  <div class="row g-5 align-items-start">

    <div class="col-12 col-md-6">
      <h1 class="fw-bold mb-3">Campus Activity Hub</h1>
      <p class="text-muted mb-4">
        A web app for WSU students to check how busy campus spots are (Library, UREC, Dining)
        and coordinate activities with friends — study sessions, gym, dinner, etc.
      </p>
      <p class="text-muted small mb-4">
        Busyness data comes from students posting crowd reports and organizers posting verified updates.
        Reports expire after 30 minutes so the info stays current.
      </p>
      <div class="d-flex gap-2">
        <a href="/signup" class="btn btn-primary">Create an account</a>
        <a href="/login" class="btn btn-outline-secondary">Log in</a>
      </div>
    </div>

    <div class="col-12 col-md-5 offset-md-1">
      <div class="card border">
        <div class="card-header bg-white fw-semibold">What you can do</div>
        <ul class="list-group list-group-flush">
          <li class="list-group-item text-muted small">Check live busyness — Library, UREC, Southside Café</li>
          <li class="list-group-item text-muted small">Post a crowd report or confirm someone else's</li>
          <li class="list-group-item text-muted small">Create a study session, workout, or dinner plan</li>
          <li class="list-group-item text-muted small">Invite friends with a shareable link, track RSVPs</li>
          <li class="list-group-item text-muted small">Check in when you arrive</li>
        </ul>
      </div>

      <div class="card border mt-3">
        <div class="card-header bg-white fw-semibold">User roles</div>
        <ul class="list-group list-group-flush">
          <li class="list-group-item text-muted small"><strong class="text-dark">Student</strong> — browse, post reports, create/join activities, add friends</li>
          <li class="list-group-item text-muted small"><strong class="text-dark">Organizer</strong> — post verified facility updates and official events</li>
          <li class="list-group-item text-muted small"><strong class="text-dark">Admin</strong> — verify organizers, manage locations, review reports</li>
        </ul>
      </div>
    </div>

  </div>
</div>

<footer class="border-top py-3 mt-4">
  <div class="container text-muted small">
    CPT_S 489 &mdash; Kaleb Kebede, Melvin Sanare, Modeste Houenou &mdash; WSU Pullman
  </div>
</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

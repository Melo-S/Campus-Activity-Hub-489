<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Organizer Dashboard — Campus Activity Hub</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/assets/css/styles.css" rel="stylesheet">
</head>
<body>

<%- include('../partials/organizer-nav', { page: 'dashboard', applicationStatus }) %>

<main class="container my-4">
  <h1 class="h5 fw-semibold mb-4">Organizer Dashboard</h1>

  <div class="card shadow-sm">
    <div class="card-body">
      <h2 class="h6 fw-semibold mb-2">Verification status</h2>
      <% if (applicationStatus === 'approved') { %>
        <span class="badge bg-success">Approved</span>
        <p class="text-muted small mt-2 mb-0">You can post verified facility updates.</p>
      <% } else if (applicationStatus === 'pending') { %>
        <span class="badge bg-warning text-dark">Pending review</span>
        <p class="text-muted small mt-2 mb-0">An admin will review your application shortly.</p>
      <% } else if (applicationStatus === 'rejected') { %>
        <span class="badge bg-danger">Rejected</span>
        <p class="text-muted small mt-2 mb-0">You may reapply from the Apply page.</p>
      <% } else { %>
        <span class="badge bg-secondary">Not applied</span>
        <p class="text-muted small mt-2 mb-0">Submit an application to request organizer verification.</p>
      <% } %>
    </div>
  </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

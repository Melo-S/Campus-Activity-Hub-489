<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Organizer Application — Campus Activity Hub</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/assets/css/styles.css" rel="stylesheet">
</head>
<body>

<%- include('../partials/organizer-nav', { page: 'apply', applicationStatus }) %>

<main class="container my-4" style="max-width:760px;">
  <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
    <div>
      <div class="pill mb-2">Organizer Candidate</div>
      <h1 class="h4 fw-semibold mb-1">Organizer Application</h1>
      <div class="text-muted">Request verification so you can post trusted facility updates.</div>
    </div>
    <% if (applicationStatus === 'pending') { %>
      <span class="badge bg-warning text-dark">Pending review</span>
    <% } else if (applicationStatus === 'rejected') { %>
      <span class="badge bg-danger">Rejected</span>
    <% } %>
  </div>

  <% if (applicationStatus === 'pending') { %>
    <div class="alert alert-warning py-2 mb-3">
      An application is already pending. Resubmitting here will replace the current request with your updated details.
    </div>
  <% } else if (applicationStatus === 'rejected') { %>
    <div class="alert alert-danger py-2 mb-3">
      Your last application was rejected. Update the details below and submit again if you still want organizer access.
    </div>
  <% } %>

  <% if (error) { %>
    <div class="alert alert-danger py-2 mb-3"><%= error %></div>
  <% } %>

  <div class="form-section">
    <h2 class="h6 fw-semibold mb-3">Application form</h2>
    <form method="POST" action="/organizer/apply">
      <div class="mb-3">
        <label class="form-label" for="organization">Organization or facility</label>
        <input
          id="organization"
          name="organization"
          type="text"
          class="form-control"
          placeholder="Example: WSU Recreation Center"
          value="<%= form.organization %>"
          required>
      </div>

      <div class="mb-3">
        <label class="form-label" for="roleTitle">Role or title</label>
        <input
          id="roleTitle"
          name="roleTitle"
          type="text"
          class="form-control"
          placeholder="Example: Student staff coordinator"
          value="<%= form.roleTitle %>"
          required>
      </div>

      <div class="mb-3">
        <label class="form-label" for="reason">Why should this account be verified?</label>
        <textarea
          id="reason"
          name="reason"
          class="form-control"
          rows="4"
          placeholder="Explain your connection to the facility and what updates you would manage."
          required><%= form.reason %></textarea>
      </div>

      <div class="mb-3">
        <label class="form-label" for="proof">Proof or contact note (optional)</label>
        <input
          id="proof"
          name="proof"
          type="text"
          class="form-control"
          placeholder="Example: supervisor email or department page"
          value="<%= form.proof %>">
      </div>

      <div class="d-flex gap-2 flex-wrap">
        <button type="submit" class="btn btn-primary btn-sm">
          <%= applicationStatus ? 'Save and resubmit' : 'Submit application' %>
        </button>
        <a href="/organizer/dashboard" class="btn btn-outline-secondary btn-sm">Back to dashboard</a>
      </div>
    </form>
  </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

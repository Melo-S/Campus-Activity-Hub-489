<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Facilities — Campus Activity Hub</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/assets/css/styles.css" rel="stylesheet">
</head>
<body>

<%- include('../partials/student-nav', { page: 'facilities' }) %>

<main class="container my-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="h4 fw-semibold mb-1">Facilities</h1>
      <p class="text-muted mb-0">Live busyness for campus spots. Click a facility to see its full update feed.</p>
    </div>
  </div>

  <div class="row g-3">
    <% facilities.forEach(f => { %>
      <div class="col-12 col-md-6 col-lg-4">
        <a href="/student/facilities/<%= f.id %>" class="text-decoration-none">
          <div class="card h-100 card-status-<%= f.status.toLowerCase() %>">
            <div class="card-body">
              <div class="d-flex justify-content-between align-items-start mb-2">
                <div>
                  <div class="section-label"><%= f.type %></div>
                  <h5 class="card-title mb-0 fw-semibold" style="font-size:0.97rem;"><%= f.name %></h5>
                </div>
                <% if (f.badge) { %>
                  <span class="badge badge-soft ms-2" style="font-size:0.7rem;"><%= f.badge %></span>
                <% } %>
              </div>
              <div class="d-flex align-items-center gap-2 my-2">
                <span class="status-dot status-dot-<%= f.status.toLowerCase() %>"></span>
                <span class="fw-semibold text-capitalize" style="font-size:1rem;"><%= f.status %></span>
              </div>
              <% if (f.updated) { %>
                <div class="text-muted" style="font-size:0.78rem;">Updated <%= f.updated %></div>
              <% } else { %>
                <div class="text-muted" style="font-size:0.78rem;">No active reports</div>
              <% } %>
              <% if (f.description) { %>
                <p class="text-muted mt-2 mb-0" style="font-size:0.8rem;"><%= f.description %></p>
              <% } %>
              <% if (f.hours) { %>
                <div class="text-muted mt-2" style="font-size:0.78rem;"><%= f.hours %></div>
              <% } %>
            </div>
            <div class="card-footer pt-2 pb-2 px-3">
              <span class="text-muted" style="font-size:0.78rem;">Tap to report →</span>
            </div>
          </div>
        </a>
      </div>
    <% }) %>
  </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

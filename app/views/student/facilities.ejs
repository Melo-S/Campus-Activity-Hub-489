<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Facilities — Campus Activity Hub</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/assets/css/styles.css" rel="stylesheet">
</head>
<body class="bg-light">

<%- include('../partials/student-nav', { page: 'facilities' }) %>

<main class="container my-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="h4 fw-semibold mb-1">Facilities</h1>
      <p class="text-muted mb-0">Live busyness for campus spots. Click a facility to see its full update feed.</p>
    </div>
  </div>

  <div class="row g-3">
    <% facilities.forEach(f => { %>
      <div class="col-12 col-md-6 col-lg-4">
        <a href="/student/facilities/<%= f.id %>" class="text-decoration-none">
          <div class="card shadow-sm h-100 hover-shadow">
            <div class="card-body">

              <%# Type pill at top %>
              <div class="text-muted small text-capitalize mb-2"><%= f.type %></div>

              <div class="d-flex justify-content-between align-items-start mb-3">
                <h5 class="card-title mb-0 fw-semibold"><%= f.name %></h5>
                <% if (f.badge) { %>
                  <span class="badge <%= f.badge === 'Verified' ? 'bg-primary' : 'bg-secondary' %>">
                    <%= f.badge %>
                  </span>
                <% } %>
              </div>

              <%# Big status display with color coding %>
              <div class="h4 mb-1 text-<%= f.statusColor %> fw-bold text-capitalize"><%= f.status %></div>

              <% if (f.updated) { %>
                <div class="text-muted small">Updated <%= f.updated %></div>
              <% } else { %>
                <div class="text-muted small">No active reports</div>
              <% } %>

              <% if (f.description) { %>
                <p class="text-muted small mt-2 mb-0"><%= f.description %></p>
              <% } %>

              <% if (f.hours) { %>
                <div class="text-muted small mt-2">
                  <span class="fw-semibold">Hours:</span> <%= f.hours %>
                </div>
              <% } %>
            </div>
            <div class="card-footer bg-transparent border-top-0 pt-0 pb-3 px-3">
              <span class="btn btn-sm btn-outline-primary w-100">View Details & Report</span>
            </div>
          </div>
        </a>
      </div>
    <% }) %>
  </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

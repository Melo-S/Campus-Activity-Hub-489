<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Create Activity — Campus Activity Hub</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/assets/css/styles.css" rel="stylesheet">
</head>
<body>

<%- include('../partials/student-nav', { page: 'none' }) %>

<main class="container my-4" style="max-width:560px;">

  <a href="/student/home" class="back-link">&larr; Home</a>
  <h1 class="h5 fw-semibold mb-4">New Activity</h1>

  <% if (error) { %>
    <div class="alert alert-danger py-2 mb-3" style="font-size:0.875rem;"><%= error %></div>
  <% } %>

  <form method="POST" action="/student/activities">

    <div class="card mb-3">
      <div class="card-header">Details</div>
      <div class="card-body">
        <div class="mb-3">
          <label class="form-label" for="title">Title</label>
          <input id="title" name="title" type="text" class="form-control"
                 placeholder="e.g. CS489 Study Group" required>
        </div>
        <div class="row g-3">
          <div class="col-6">
            <label class="form-label" for="type">Type</label>
            <select id="type" name="type" class="form-select">
              <option value="study">📖 Study</option>
              <option value="workout">⚡ Workout</option>
              <option value="dinner">🍽️ Dinner</option>
              <option value="other">• Other</option>
            </select>
          </div>
          <div class="col-6">
            <label class="form-label" for="maxParticipants">Max people</label>
            <input id="maxParticipants" name="maxParticipants" type="number"
                   class="form-control" placeholder="Unlimited" min="1">
          </div>
        </div>
      </div>
    </div>

    <div class="card mb-3">
      <div class="card-header">When & Where</div>
      <div class="card-body">
        <div class="mb-3">
          <label class="form-label" for="scheduledAt">Date & time</label>
          <input id="scheduledAt" name="scheduledAt" type="datetime-local" class="form-control" required>
        </div>
        <div>
          <label class="form-label" for="locationId">Location</label>
          <select id="locationId" name="locationId" class="form-select">
            <option value="">No specific location</option>
            <% locations.forEach(loc => { %>
              <option value="<%= loc.id %>"><%= loc.name %></option>
            <% }) %>
          </select>
        </div>
      </div>
    </div>

    <div class="card mb-4">
      <div class="card-header">Description <span style="font-weight:400;color:#999;">(optional)</span></div>
      <div class="card-body">
        <textarea id="description" name="description" class="form-control border-0 p-0"
                  rows="3" placeholder="What are you doing? What should people bring?"
                  style="resize:none;font-size:0.9rem;"></textarea>
      </div>
    </div>

    <button type="submit" class="btn btn-primary w-100">Create Activity</button>
  </form>

</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

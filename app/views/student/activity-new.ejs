<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Create Activity — Campus Activity Hub</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/assets/css/styles.css" rel="stylesheet">
</head>
<body>

<%- include('../partials/student-nav', { page: 'none' }) %>

<main class="container my-4" style="max-width: 580px;">
  <a href="/student/home" class="text-muted small text-decoration-none d-inline-block mb-3">&larr; Back to Home</a>

  <h1 class="h4 fw-semibold mb-1">Create an Activity</h1>
  <p class="text-muted mb-4">Set up a study session, workout, dinner plan, or anything else.</p>

  <% if (error) { %>
    <div class="alert alert-danger py-2"><%= error %></div>
  <% } %>

  <%# Form POSTs to /student/activities which maps to createActivity in the controller %>
  <form method="POST" action="/student/activities">

    <div class="mb-3">
      <label class="form-label fw-semibold" for="title">Activity title</label>
      <input id="title" name="title" type="text" class="form-control"
             placeholder="e.g. CS489 Study Group" required>
    </div>

    <div class="mb-3">
      <label class="form-label fw-semibold" for="type">Type</label>
      <select id="type" name="type" class="form-select">
        <option value="study">Study</option>
        <option value="workout">Workout</option>
        <option value="dinner">Dinner</option>
        <option value="other">Other</option>
      </select>
    </div>

    <div class="mb-3">
      <label class="form-label fw-semibold" for="locationId">Location (optional)</label>
      <select id="locationId" name="locationId" class="form-select">
        <option value="">-- No specific location --</option>
        <% locations.forEach(loc => { %>
          <option value="<%= loc.id %>"><%= loc.name %></option>
        <% }) %>
      </select>
    </div>

    <div class="mb-3">
      <label class="form-label fw-semibold" for="scheduledAt">Date & time</label>
      <%# datetime-local gives a date+time picker in the browser %>
      <input id="scheduledAt" name="scheduledAt" type="datetime-local" class="form-control" required>
    </div>

    <div class="mb-3">
      <label class="form-label fw-semibold" for="maxParticipants">Max participants (optional)</label>
      <input id="maxParticipants" name="maxParticipants" type="number" class="form-control"
             placeholder="Leave blank for unlimited" min="1">
    </div>

    <div class="mb-4">
      <label class="form-label fw-semibold" for="description">Description (optional)</label>
      <textarea id="description" name="description" class="form-control" rows="3"
                placeholder="What are you doing? What should people bring?"></textarea>
    </div>

    <button type="submit" class="btn btn-primary w-100">Create Activity</button>
  </form>
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

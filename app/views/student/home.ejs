<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Home — Campus Activity Hub</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/assets/css/styles.css" rel="stylesheet">
</head>
<body class="bg-light">

<%- include('../partials/student-nav', { page: 'home' }) %>

<main class="container my-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="h4 fw-semibold mb-1">Welcome, <%= currentUser.name.split(' ')[0] %></h1>
      <p class="text-muted mb-0">Here's what's happening on campus right now.</p>
    </div>
    <a href="/student/activities/new" class="btn btn-primary d-none d-md-inline-block">
      + Create Activity
    </a>
  </div>

  <%# Bootstrap tabs — the active tab persists with the data-bs-toggle="tab" JS attribute %>
  <ul class="nav nav-tabs mb-3" role="tablist">
    <li class="nav-item">
      <a class="nav-link active" data-bs-toggle="tab" href="#tab-now">Happening Now</a>
    </li>
    <li class="nav-item">
      <a class="nav-link" data-bs-toggle="tab" href="#tab-today">Today</a>
    </li>
    <li class="nav-item">
      <a class="nav-link" data-bs-toggle="tab" href="#tab-friends">Friends</a>
    </li>
  </ul>

  <div class="tab-content">

    <%# ── Happening Now tab: facility busyness cards ── %>
    <div class="tab-pane fade show active" id="tab-now">
      <div class="row g-3">
        <% facilities.forEach(f => { %>
          <div class="col-12 col-md-4">
            <a href="/student/facilities/<%= f.id %>" class="text-decoration-none">
              <div class="card shadow-sm h-100">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-start mb-2">
                    <span class="fw-semibold text-dark"><%= f.name %></span>
                    <% if (f.badge) { %>
                      <span class="badge <%= f.badge === 'Verified' ? 'bg-primary' : 'bg-secondary' %>">
                        <%= f.badge %>
                      </span>
                    <% } %>
                  </div>
                  <%# status color comes from the controller's statusColor() helper %>
                  <div class="h4 mb-0 text-<%= f.statusColor %> fw-bold text-capitalize">
                    <%= f.status %>
                  </div>
                  <div class="text-muted small mt-1">
                    <% if (f.updated) { %>Updated <%= f.updated %><% } else { %>No active reports<% } %>
                  </div>
                </div>
              </div>
            </a>
          </div>
        <% }) %>
      </div>
    </div>

    <%# ── Today tab: activities scheduled for today ── %>
    <div class="tab-pane fade" id="tab-today">
      <% if (todayActivities.length === 0) { %>
        <div class="text-center py-5 text-muted">
          <p class="mb-2">No activities scheduled for today.</p>
          <a href="/student/activities/new" class="btn btn-outline-primary btn-sm">Create one</a>
        </div>
      <% } else { %>
        <div class="row g-3">
          <% todayActivities.forEach(a => { %>
            <div class="col-12 col-md-6">
              <a href="/student/activities/<%= a.id %>" class="text-decoration-none">
                <div class="card shadow-sm h-100">
                  <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-1">
                      <span class="fw-semibold text-dark"><%= a.title %></span>
                      <span class="badge bg-light text-dark border text-capitalize"><%= a.type %></span>
                    </div>
                    <div class="text-muted small mb-2">
                      <%# .toLocaleTimeString formats the stored Date into "2:30 PM" %>
                      <%= new Date(a.scheduledAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) %>
                      <% if (a.Location) { %> &middot; <%= a.Location.name %><% } %>
                    </div>
                    <div class="text-muted small">
                      By <%= a.creator.name %> &middot;
                      <%= a.Participants.length %><% if (a.maxParticipants) { %>/<%= a.maxParticipants %><% } %> going
                    </div>
                  </div>
                </div>
              </a>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <%# ── Friends tab: upcoming activities from accepted friends ── %>
    <div class="tab-pane fade" id="tab-friends">
      <% if (friendActivities.length === 0) { %>
        <div class="text-center py-5 text-muted">
          <p class="mb-2">No upcoming activities from your friends.</p>
          <a href="/student/friends" class="btn btn-outline-primary btn-sm">Manage Friends</a>
        </div>
      <% } else { %>
        <div class="row g-3">
          <% friendActivities.forEach(a => { %>
            <div class="col-12 col-md-6">
              <a href="/student/activities/<%= a.id %>" class="text-decoration-none">
                <div class="card shadow-sm h-100">
                  <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-1">
                      <span class="fw-semibold text-dark"><%= a.title %></span>
                      <span class="badge bg-light text-dark border text-capitalize"><%= a.type %></span>
                    </div>
                    <div class="text-muted small mb-2">
                      <%= new Date(a.scheduledAt).toLocaleDateString([], { month: 'short', day: 'numeric' }) %>
                      at <%= new Date(a.scheduledAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) %>
                      <% if (a.Location) { %> &middot; <%= a.Location.name %><% } %>
                    </div>
                    <div class="text-muted small">
                      By <%= a.creator.name %> &middot;
                      <%= a.Participants.length %><% if (a.maxParticipants) { %>/<%= a.maxParticipants %><% } %> going
                    </div>
                  </div>
                </div>
              </a>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

  </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

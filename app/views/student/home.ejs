<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Home — Campus Activity Hub</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/assets/css/styles.css" rel="stylesheet">
</head>
<body>

<%- include('../partials/student-nav', { page: 'home' }) %>

<main class="container my-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h5 fw-semibold mb-0">Campus Activity Hub</h1>
    <a href="/student/activities/new" class="btn btn-primary btn-sm d-none d-md-inline-block">+ Create Activity</a>
  </div>

  <%# Bootstrap tabs — the active tab persists with the data-bs-toggle="tab" JS attribute %>
  <ul class="nav nav-tabs mb-3" role="tablist">
    <li class="nav-item">
      <a class="nav-link active" data-bs-toggle="tab" href="#tab-now">Happening Now</a>
    </li>
    <li class="nav-item">
      <a class="nav-link" data-bs-toggle="tab" href="#tab-today">Today</a>
    </li>
    <li class="nav-item">
      <a class="nav-link" data-bs-toggle="tab" href="#tab-friends">Friends</a>
    </li>
  </ul>

  <div class="tab-content">

    <%# ── Happening Now tab: facility busyness cards ── %>
    <div class="tab-pane fade show active" id="tab-now">
      <div class="row g-3">
        <% facilities.forEach(f => { %>
          <div class="col-12 col-md-4">
            <a href="/student/facilities/<%= f.id %>" class="text-decoration-none">
              <div class="card h-100 card-status-<%= f.status.toLowerCase() %>">
                <div class="card-body">
                  <div class="d-flex justify-content-between align-items-start mb-2">
                    <span class="fw-semibold" style="font-size:0.92rem;"><%= f.name %></span>
                    <% if (f.badge) { %>
                      <span class="badge badge-soft ms-2 text-capitalize" style="font-size:0.7rem;"><%= f.badge %></span>
                    <% } %>
                  </div>
                  <div class="d-flex align-items-center gap-2 mb-1">
                    <span class="status-dot status-dot-<%= f.status.toLowerCase() %>"></span>
                    <span class="fw-semibold text-capitalize" style="font-size:0.95rem;">
                      <%= f.status %>
                    </span>
                  </div>
                  <div class="text-muted" style="font-size:0.78rem;">
                    <% if (f.updated) { %><%= f.updated %><% } else { %>No reports yet<% } %>
                  </div>
                </div>
              </div>
            </a>
          </div>
        <% }) %>
      </div>
    </div>

    <%# ── Today tab: activities scheduled for today ── %>
    <div class="tab-pane fade" id="tab-today">
      <% if (todayActivities.length === 0) { %>
        <div class="text-center py-5 text-muted">
          <p class="mb-2">No activities scheduled for today.</p>
          <a href="/student/activities/new" class="btn btn-outline-primary btn-sm">Create one</a>
        </div>
      <% } else { %>
        <div class="row g-3">
          <% todayActivities.forEach(a => { %>
            <div class="col-12 col-md-6">
              <a href="/student/activities/<%= a.id %>" class="text-decoration-none">
                <div class="card shadow-sm h-100">
                  <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-2">
                      <span class="fw-semibold" style="font-size:0.92rem;"><%= a.title %></span>
                      <span class="activity-chip ms-2"><%= a.type %></span>
                    </div>
                    <div class="text-muted mb-2" style="font-size:0.8rem;">
                      <%= new Date(a.scheduledAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) %>
                      <% if (a.Location) { %>&nbsp;&middot; <%= a.Location.name %><% } %>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                      <span class="avatar avatar-sm"><%= a.creator.name.charAt(0) %></span>
                      <span class="text-muted" style="font-size:0.78rem;">
                        <%= a.creator.name %> &middot; <%= a.Participants.length %><% if (a.maxParticipants) { %>/<%= a.maxParticipants %><% } %> going
                      </span>
                    </div>
                  </div>
                </div>
              </a>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

    <%# ── Friends tab: upcoming activities from accepted friends ── %>
    <div class="tab-pane fade" id="tab-friends">
      <% if (friendActivities.length === 0) { %>
        <div class="text-center py-5 text-muted">
          <p class="mb-2">No upcoming activities from your friends.</p>
          <a href="/student/friends" class="btn btn-outline-primary btn-sm">Manage Friends</a>
        </div>
      <% } else { %>
        <div class="row g-3">
          <% friendActivities.forEach(a => { %>
            <div class="col-12 col-md-6">
              <a href="/student/activities/<%= a.id %>" class="text-decoration-none">
                <div class="card shadow-sm h-100">
                  <div class="card-body">
                    <div class="d-flex justify-content-between align-items-start mb-1">
                      <span class="fw-semibold text-dark"><%= a.title %></span>
                      <span class="badge bg-light text-dark border text-capitalize"><%= a.type %></span>
                    </div>
                    <div class="text-muted small mb-2">
                      <%= new Date(a.scheduledAt).toLocaleDateString([], { month: 'short', day: 'numeric' }) %>
                      at <%= new Date(a.scheduledAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) %>
                      <% if (a.Location) { %> &middot; <%= a.Location.name %><% } %>
                    </div>
                    <div class="text-muted small">
                      By <%= a.creator.name %> &middot;
                      <%= a.Participants.length %><% if (a.maxParticipants) { %>/<%= a.maxParticipants %><% } %> going
                    </div>
                  </div>
                </div>
              </a>
            </div>
          <% }) %>
        </div>
      <% } %>
    </div>

  </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

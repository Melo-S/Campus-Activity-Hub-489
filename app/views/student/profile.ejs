<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>My Profile — Campus Activity Hub</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/assets/css/styles.css" rel="stylesheet">
</head>
<body>

<%- include('../partials/student-nav', { page: 'profile' }) %>

<main class="container my-4" style="max-width: 560px;">
  <h1 class="h4 fw-semibold mb-1">My Profile</h1>
  <p class="text-muted mb-4">Update your name, email, or password.</p>

  <%# Success / error banners — driven by ?success= and ?error= query params %>
  <% if (success === 'profile') { %>
    <div class="alert alert-success py-2">Profile updated successfully.</div>
  <% } else if (success === 'password') { %>
    <div class="alert alert-success py-2">Password changed successfully.</div>
  <% } %>
  <% if (error) { %>
    <div class="alert alert-danger py-2"><%= error %></div>
  <% } %>

  <%# ── Update name + email ── %>
  <div class="card shadow-sm mb-4">
    <div class="card-body p-4">
      <h6 class="fw-semibold mb-3">Account details</h6>
      <form method="POST" action="/student/profile">
        <div class="mb-3">
          <label class="form-label" for="name">Full name</label>
          <input id="name" name="name" type="text" class="form-control"
                 value="<%= user.name %>" required>
        </div>
        <div class="mb-3">
          <label class="form-label" for="email">Email address</label>
          <input id="email" name="email" type="email" class="form-control"
                 value="<%= user.email %>" required>
        </div>
        <div class="mb-3">
          <label class="form-label">Role</label>
          <%# Role is not editable — displayed for info only %>
          <input type="text" class="form-control text-capitalize" value="<%= user.role %>" disabled>
        </div>
        <button type="submit" class="btn btn-primary">Save Changes</button>
      </form>
    </div>
  </div>

  <%# ── Change password ── %>
  <div class="card shadow-sm">
    <div class="card-body p-4">
      <h6 class="fw-semibold mb-3">Change password</h6>
      <form method="POST" action="/student/profile/password">
        <div class="mb-3">
          <label class="form-label" for="currentPassword">Current password</label>
          <input id="currentPassword" name="currentPassword" type="password"
                 class="form-control" required>
        </div>
        <div class="mb-3">
          <label class="form-label" for="newPassword">New password</label>
          <input id="newPassword" name="newPassword" type="password"
                 class="form-control" placeholder="At least 6 characters" required minlength="6">
        </div>
        <div class="mb-3">
          <label class="form-label" for="confirmNewPassword">Confirm new password</label>
          <input id="confirmNewPassword" name="confirmNewPassword" type="password"
                 class="form-control" required>
        </div>
        <button type="submit" class="btn btn-outline-primary">Change Password</button>
      </form>
    </div>
  </div>

</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

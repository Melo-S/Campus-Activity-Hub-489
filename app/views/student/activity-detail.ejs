<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= activity.title %> — Campus Activity Hub</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/assets/css/styles.css" rel="stylesheet">
</head>
<body>

<%- include('../partials/student-nav', { page: 'none' }) %>

<main class="container my-4" style="max-width:620px;">

  <a href="/student/home" class="back-link">&larr; Home</a>

  <% if (error === 'full') { %>
    <div class="alert alert-warning py-2 mb-3" style="font-size:0.875rem;">This activity is full.</div>
  <% } %>

  <%# Main activity card %>
  <div class="card mb-4">
    <div class="card-body">
      <%
        const detIconMap = { study:'bi-journal-text', workout:'bi-lightning-charge', dinner:'bi-cup-hot', other:'bi-three-dots' };
      %>
      <div class="d-flex justify-content-between align-items-start mb-3">
        <span class="activity-chip"><i class="bi <%= detIconMap[activity.type] || 'bi-three-dots' %>"></i> <%= activity.type %></span>
        <% if (inviteUrl) { %>
          <div class="text-end" style="max-width:200px;">
            <div style="font-size:0.72rem;color:#888;margin-bottom:3px;">Invite link</div>
            <code class="user-select-all" style="font-size:0.75rem;word-break:break-all;"><%= inviteUrl %></code>
          </div>
        <% } %>
      </div>

      <h2 class="fw-semibold mb-1" style="font-size:1.2rem;"><%= activity.title %></h2>

      <div class="mb-3" style="font-size:0.82rem;color:#666;">
        <%= new Date(activity.scheduledAt).toLocaleDateString([], { weekday:'long', month:'short', day:'numeric' }) %>
        at <%= new Date(activity.scheduledAt).toLocaleTimeString([], { hour:'2-digit', minute:'2-digit' }) %>
        <% if (activity.Location) { %>&nbsp;· <%= activity.Location.name %><% } %>
      </div>

      <% if (activity.description) { %>
        <p class="mb-3" style="font-size:0.9rem;color:#333;"><%= activity.description %></p>
      <% } %>

      <div class="d-flex align-items-center gap-2">
        <span class="avatar avatar-sm"><%= activity.creator.name.charAt(0) %></span>
        <span style="font-size:0.8rem;color:#666;">
          <%= activity.creator.name %> &middot;
          <% if (activity.maxParticipants) { %>
            <%= rsvpCount %>/<%= activity.maxParticipants %> going
          <% } else { %>
            <%= rsvpCount %> going
          <% } %>
        </span>
      </div>
    </div>

    <div class="card-footer d-flex align-items-center gap-2">
      <% if (!myParticipant) { %>
        <form method="POST" action="/student/activities/<%= activity.id %>/rsvp">
          <button type="submit" class="btn btn-primary btn-sm">RSVP</button>
        </form>
      <% } else if (myParticipant.status === 'rsvp') { %>
        <span class="badge" style="background:#dcfce7;color:#166534;font-size:0.78rem;padding:5px 10px;">RSVP'd</span>
        <form method="POST" action="/student/activities/<%= activity.id %>/checkin">
          <button type="submit" class="btn btn-sm btn-outline-success">Check In</button>
        </form>
      <% } else { %>
        <span class="badge" style="background:#dcfce7;color:#166534;font-size:0.78rem;padding:5px 10px;">Checked In</span>
      <% } %>
      <% if (activity.creatorId !== currentUser.id) { %>
        <a href="/student/report?contentType=activity&contentId=<%= activity.id %>"
           class="ms-auto text-muted" style="font-size:0.78rem;">Report</a>
      <% } %>
    </div>
  </div>

  <%# Participant list %>
  <div class="section-label mb-2">Who's going (<%= rsvpCount %>)</div>

  <% if (activity.Participants.length === 0) { %>
    <div class="card"><div class="empty-state">No one has RSVP'd yet.</div></div>
  <% } else { %>
    <div class="card">
      <% activity.Participants.forEach((p, i) => { %>
        <div class="d-flex align-items-center justify-content-between px-3 py-2
          <%= i < activity.Participants.length - 1 ? 'border-bottom' : '' %>"
          style="border-color:#f0f0f0;">
          <div class="d-flex align-items-center gap-2">
            <span class="avatar avatar-sm"><%= p.User.name.charAt(0) %></span>
            <span style="font-size:0.88rem;"><%= p.User.name %></span>
          </div>
          <% if (p.status === 'checked_in') { %>
            <span style="font-size:0.75rem;color:#16a34a;font-weight:600;">Checked in</span>
          <% } else { %>
            <span style="font-size:0.75rem;color:#888;">RSVP'd</span>
          <% } %>
        </div>
      <% }) %>
    </div>
  <% } %>

</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

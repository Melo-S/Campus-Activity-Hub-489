<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= activity.title %> — Campus Activity Hub</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/assets/css/styles.css" rel="stylesheet">
</head>
<body>

<%- include('../partials/student-nav', { page: 'none' }) %>

<main class="container my-4" style="max-width: 640px;">
  <a href="/student/home" class="text-muted small text-decoration-none d-inline-block mb-3">&larr; Back to Home</a>

  <% if (error === 'full') { %>
    <div class="alert alert-warning py-2">This activity is full and can't accept more RSVPs.</div>
  <% } %>

  <%# Activity header card %>
  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <div class="d-flex justify-content-between align-items-start mb-2">
        <span class="badge bg-light text-dark border text-capitalize"><%= activity.type %></span>
        <% if (inviteUrl) { %>
          <%# Shareable link — anyone with this URL can join directly %>
          <div class="text-end">
            <div class="text-muted small mb-1">Invite link:</div>
            <code class="small user-select-all"><%= inviteUrl %></code>
          </div>
        <% } %>
      </div>

      <h2 class="h4 fw-semibold mb-1"><%= activity.title %></h2>

      <div class="text-muted small mb-3">
        <%# Format the stored Date into a readable date + time string %>
        <%= new Date(activity.scheduledAt).toLocaleDateString([], { weekday: 'long', month: 'short', day: 'numeric' }) %>
        at <%= new Date(activity.scheduledAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) %>
        <% if (activity.Location) { %> &middot; <%= activity.Location.name %><% } %>
      </div>

      <% if (activity.description) { %>
        <p class="mb-3"><%= activity.description %></p>
      <% } %>

      <div class="text-muted small">
        Created by <strong><%= activity.creator.name %></strong> &middot;
        <% if (activity.maxParticipants) { %>
          <%= rsvpCount %> / <%= activity.maxParticipants %> going
        <% } else { %>
          <%= rsvpCount %> going
        <% } %>
      </div>
    </div>

    <%# RSVP / Check-in action area %>
    <div class="card-footer bg-transparent d-flex justify-content-between align-items-center gap-2">
      <% if (!myParticipant) { %>
        <%# Not joined yet — show the RSVP button %>
        <form method="POST" action="/student/activities/<%= activity.id %>/rsvp">
          <button type="submit" class="btn btn-primary">RSVP</button>
        </form>
      <% } else if (myParticipant.status === 'rsvp') { %>
        <%# Already RSVP'd — offer check-in %>
        <span class="btn btn-success disabled">RSVP'd</span>
        <form method="POST" action="/student/activities/<%= activity.id %>/checkin">
          <button type="submit" class="btn btn-outline-success">Check In</button>
        </form>
      <% } else { %>
        <%# Already checked in %>
        <span class="btn btn-success disabled">Checked In</span>
      <% } %>

      <%# Report link — only show if this user didn't create the activity %>
      <% if (activity.creatorId !== currentUser.id) { %>
        <a href="/student/report?contentType=activity&contentId=<%= activity.id %>"
           class="btn btn-sm btn-outline-secondary ms-auto">Report</a>
      <% } %>
    </div>
  </div>

  <%# Participant list %>
  <h6 class="fw-semibold mb-3">Who's going (<%= rsvpCount %>)</h6>

  <% if (activity.Participants.length === 0) { %>
    <p class="text-muted">No one has RSVP'd yet.</p>
  <% } else { %>
    <div class="list-group shadow-sm">
      <% activity.Participants.forEach(p => { %>
        <div class="list-group-item d-flex justify-content-between align-items-center">
          <span><%= p.User.name %></span>
          <% if (p.status === 'checked_in') { %>
            <span class="badge bg-success">Checked In</span>
          <% } else { %>
            <span class="badge bg-light text-dark border">RSVP'd</span>
          <% } %>
        </div>
      <% }) %>
    </div>
  <% } %>

</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

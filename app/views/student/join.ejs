<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Join Activity — Campus Activity Hub</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/assets/css/styles.css" rel="stylesheet">
</head>
<body class="bg-light">

<%- include('../partials/student-nav', { page: 'none' }) %>

<main class="container my-5" style="max-width: 520px;">

  <% if (!activity) { %>
    <%# Invite code didn't match any activity in the DB %>
    <div class="card shadow-sm text-center p-5">
      <h2 class="h5 fw-semibold mb-2">Invalid invite link</h2>
      <p class="text-muted mb-4">The code <code><%= code %></code> doesn't match any activity.</p>
      <a href="/student/home" class="btn btn-primary">Go to Home</a>
    </div>

  <% } else if (alreadyJoined) { %>
    <%# User already RSVP'd — just send them to the activity page %>
    <div class="card shadow-sm text-center p-5">
      <h2 class="h5 fw-semibold mb-2">You're already in!</h2>
      <p class="text-muted mb-4">You've already RSVP'd to <strong><%= activity.title %></strong>.</p>
      <a href="/student/activities/<%= activity.id %>" class="btn btn-primary">View Activity</a>
    </div>

  <% } else if (req.query.error === 'full') { %>
    <div class="card shadow-sm text-center p-5">
      <h2 class="h5 fw-semibold mb-2">Activity is full</h2>
      <p class="text-muted mb-4"><strong><%= activity.title %></strong> has reached its participant limit.</p>
      <a href="/student/home" class="btn btn-outline-primary">Back to Home</a>
    </div>

  <% } else { %>
    <%# Show a preview of the activity and let them confirm their RSVP %>
    <div class="card shadow-sm">
      <div class="card-body p-4">
        <div class="text-muted small text-capitalize mb-1"><%= activity.type %></div>
        <h2 class="h4 fw-semibold mb-1"><%= activity.title %></h2>

        <div class="text-muted small mb-3">
          <%= new Date(activity.scheduledAt).toLocaleDateString([], { weekday: 'long', month: 'short', day: 'numeric' }) %>
          at <%= new Date(activity.scheduledAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' }) %>
          <% if (activity.Location) { %> &middot; <%= activity.Location.name %><% } %>
        </div>

        <% if (activity.description) { %>
          <p class="mb-3"><%= activity.description %></p>
        <% } %>

        <div class="text-muted small mb-4">
          Organized by <strong><%= activity.creator.name %></strong> &middot;
          <%= activity.Participants.length %>
          <% if (activity.maxParticipants) { %>/ <%= activity.maxParticipants %><% } %> going
        </div>

        <%# POST to the same /join/:code URL — controller handles RSVP creation %>
        <form method="POST" action="/join/<%= code %>">
          <button type="submit" class="btn btn-primary w-100">Join this activity</button>
        </form>
        <a href="/student/home" class="btn btn-outline-secondary w-100 mt-2">Maybe later</a>
      </div>
    </div>
  <% } %>

</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

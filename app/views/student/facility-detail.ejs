<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= location.name %> — Campus Activity Hub</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/assets/css/styles.css" rel="stylesheet">
</head>
<body class="bg-light">

<%- include('../partials/student-nav', { page: 'facilities' }) %>

<main class="container my-4" style="max-width: 700px;">

  <%# Back link %>
  <a href="/student/facilities" class="text-muted small text-decoration-none d-inline-block mb-3">&larr; All Facilities</a>

  <%# Header card showing current status %>
  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <div class="text-muted small text-capitalize mb-1"><%= location.type %></div>
      <div class="d-flex justify-content-between align-items-start">
        <h2 class="h4 fw-semibold mb-0"><%= location.name %></h2>
        <% if (latest) { %>
          <%# Real report — show status with source badge %>
          <div class="text-end">
            <span class="badge bg-<%= latest.statusColor %> fs-6 text-capitalize d-block mb-1"><%= latest.status %></span>
            <span class="badge <%= latest.type === 'verified' ? 'bg-primary' : 'bg-secondary' %>">
              <%= latest.type === 'verified' ? 'Verified' : 'Crowd report' %>
            </span>
          </div>
        <% } else if (typicalStatus) { %>
          <%# No real report — show algorithm estimate %>
          <div class="text-end">
            <span class="badge bg-<%= {light:'success',moderate:'warning',busy:'danger'}[typicalStatus] || 'secondary' %> fs-6 text-capitalize d-block mb-1"><%= typicalStatus %></span>
            <span class="badge bg-light text-dark border">Typical pattern</span>
          </div>
        <% } else { %>
          <span class="badge bg-secondary fs-6">Closed</span>
        <% } %>
      </div>
      <% if (location.description) { %>
        <p class="text-muted mt-2 mb-0 small"><%= location.description %></p>
      <% } %>
      <% if (location.hours) { %>
        <div class="text-muted small mt-2">
          <span class="fw-semibold">Hours:</span> <%= location.hours %>
        </div>
      <% } %>
    </div>
  </div>

  <%# Error banner %>
  <% if (error) { %>
    <div class="alert alert-danger py-2">Invalid status value. Please try again.</div>
  <% } %>

  <%# Submit a report card %>
  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <h6 class="fw-semibold mb-3">How busy is it right now?</h6>
      <form method="POST" action="/student/facilities/<%= location.id %>/updates">
        <div class="d-flex gap-2 flex-wrap">
          <%# Each button submits the form with a different status value %>
          <button type="submit" name="status" value="light"
                  class="btn btn-outline-success flex-fill">
            Light
            <div class="small opacity-75">Easy to find a spot</div>
          </button>
          <button type="submit" name="status" value="moderate"
                  class="btn btn-outline-warning flex-fill">
            Moderate
            <div class="small opacity-75">Getting busy</div>
          </button>
          <button type="submit" name="status" value="busy"
                  class="btn btn-outline-danger flex-fill">
            Busy
            <div class="small opacity-75">Hard to find a spot</div>
          </button>
        </div>
      </form>
    </div>
  </div>

  <%# Active update feed %>
  <h6 class="fw-semibold mb-3">Active Reports</h6>

  <% if (feed.length === 0) { %>
    <div class="card shadow-sm">
      <div class="card-body text-center text-muted py-4">
        No active reports right now. Be the first to post one above!
      </div>
    </div>
  <% } else { %>
    <% feed.forEach(u => { %>
      <div class="card shadow-sm mb-2">
        <div class="card-body py-3">
          <div class="d-flex justify-content-between align-items-center flex-wrap gap-2">

            <%# Left: status + who posted it %>
            <div>
              <span class="badge bg-<%= u.statusColor %> text-capitalize me-1"><%= u.status %></span>
              <% if (u.type === 'verified') { %>
                <span class="badge bg-primary me-1">Verified</span>
              <% } %>
              <span class="text-muted small">
                <%= u.postedBy %> &middot; <%= u.posted %>
              </span>
            </div>

            <%# Right: confirm / disagree vote buttons %>
            <div class="d-flex gap-2">
              <form method="POST"
                    action="/student/facilities/<%= location.id %>/updates/<%= u.id %>/vote">
                <input type="hidden" name="type" value="confirm">
                <button class="btn btn-sm <%= u.myVote === 'confirm' ? 'btn-success' : 'btn-outline-success' %>">
                  Confirm (<%= u.confirms %>)
                </button>
              </form>
              <form method="POST"
                    action="/student/facilities/<%= location.id %>/updates/<%= u.id %>/vote">
                <input type="hidden" name="type" value="disagree">
                <button class="btn btn-sm <%= u.myVote === 'disagree' ? 'btn-danger' : 'btn-outline-danger' %>">
                  Disagree (<%= u.disagrees %>)
                </button>
              </form>
            </div>

          </div>
        </div>
      </div>
    <% }) %>
  <% } %>

</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

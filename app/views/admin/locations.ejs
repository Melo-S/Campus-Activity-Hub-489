<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Manage Locations — Campus Activity Hub</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/assets/css/styles.css" rel="stylesheet">
</head>
<body>

<%- include('../partials/admin-nav', { page: 'locations' }) %>

<main class="container my-4">
  <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
    <div>
      <div class="pill mb-2">Admin</div>
      <h1 class="h4 fw-semibold mb-1">Manage locations</h1>
      <div class="text-muted">Create, update, and delete campus locations used across the app.</div>
    </div>
  </div>

  <% if (success === 'created') { %>
    <div class="alert alert-success py-2 mb-3">Location created.</div>
  <% } else if (success === 'updated') { %>
    <div class="alert alert-success py-2 mb-3">Location updated.</div>
  <% } else if (success === 'deleted') { %>
    <div class="alert alert-warning py-2 mb-3">Location deleted.</div>
  <% } %>

  <% if (error === 'invalid') { %>
    <div class="alert alert-danger py-2 mb-3">Please enter a location name and a valid type.</div>
  <% } else if (error === 'linked') { %>
    <div class="alert alert-danger py-2 mb-3">This location cannot be deleted because activities or status updates still reference it.</div>
  <% } else if (error === 'notfound') { %>
    <div class="alert alert-danger py-2 mb-3">That location could not be found.</div>
  <% } %>

  <div class="card shadow-sm mb-4">
    <div class="card-body">
      <h2 class="h6 fw-semibold mb-3">Add location</h2>
      <form method="POST" action="/admin/locations">
        <div class="row g-3">
          <div class="col-12 col-lg-4">
            <label class="form-label" for="new-name">Name</label>
            <input id="new-name" name="name" type="text" class="form-control" placeholder="Example: Smith Gym" required>
          </div>
          <div class="col-12 col-lg-3">
            <label class="form-label" for="new-type">Type</label>
            <select id="new-type" name="type" class="form-select">
              <% locationTypes.forEach((type) => { %>
                <option value="<%= type %>"><%= type %></option>
              <% }) %>
            </select>
          </div>
          <div class="col-12 col-lg-5">
            <label class="form-label" for="new-hours">Hours</label>
            <input id="new-hours" name="hours" type="text" class="form-control" placeholder="Example: Mon–Fri 6am–9pm">
          </div>
          <div class="col-12">
            <label class="form-label" for="new-description">Description</label>
            <textarea id="new-description" name="description" class="form-control" rows="2" placeholder="Short summary students will see on the facility page."></textarea>
          </div>
          <div class="col-12">
            <button type="submit" class="btn btn-primary btn-sm">Create location</button>
          </div>
        </div>
      </form>
    </div>
  </div>

  <% locationCards.forEach(({ location, statusUpdateCount, activityCount, canDelete }) => { %>
    <div class="card shadow-sm mb-3">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-3">
          <div>
            <div class="fw-semibold"><%= location.name %></div>
            <div class="text-muted small text-capitalize"><%= location.type %></div>
          </div>
          <div class="text-muted small">
            <%= statusUpdateCount %> update(s) · <%= activityCount %> activit<%= activityCount === 1 ? 'y' : 'ies' %>
          </div>
        </div>

        <form method="POST" action="/admin/locations/<%= location.id %>/update">
          <div class="row g-3">
            <div class="col-12 col-lg-4">
              <label class="form-label">Name</label>
              <input name="name" type="text" class="form-control" value="<%= location.name %>" required>
            </div>
            <div class="col-12 col-lg-3">
              <label class="form-label">Type</label>
              <select name="type" class="form-select">
                <% locationTypes.forEach((type) => { %>
                  <option value="<%= type %>" <%= location.type === type ? 'selected' : '' %>><%= type %></option>
                <% }) %>
              </select>
            </div>
            <div class="col-12 col-lg-5">
              <label class="form-label">Hours</label>
              <input name="hours" type="text" class="form-control" value="<%= location.hours || '' %>">
            </div>
            <div class="col-12">
              <label class="form-label">Description</label>
              <textarea name="description" class="form-control" rows="2"><%= location.description || '' %></textarea>
            </div>
            <div class="col-12 d-flex gap-2 flex-wrap">
              <button type="submit" class="btn btn-success btn-sm">Save changes</button>
            </div>
          </div>
        </form>

        <form method="POST" action="/admin/locations/<%= location.id %>/delete" class="mt-3">
          <button type="submit" class="btn btn-outline-danger btn-sm" <%= canDelete ? '' : 'disabled' %>>Delete location</button>
          <% if (!canDelete) { %>
            <span class="text-muted small ms-2">Delete is blocked because this location still has linked content.</span>
          <% } %>
        </form>
      </div>
    </div>
  <% }) %>
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Verification Queue — Campus Activity Hub</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/assets/css/styles.css" rel="stylesheet">
</head>
<body>

<%- include('../partials/admin-nav', { page: 'verification' }) %>

<main class="container my-4">
  <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-4">
    <div>
      <div class="pill mb-2">Admin</div>
      <h1 class="h4 fw-semibold mb-1">Verification Requests Queue</h1>
      <div class="text-muted">Approve or reject organizer applications before verified update tools are unlocked.</div>
    </div>
  </div>

  <% if (success === 'approved') { %>
    <div class="alert alert-success py-2 mb-3">Organizer approved. Their dashboard now shows approved status.</div>
  <% } else if (success === 'rejected') { %>
    <div class="alert alert-warning py-2 mb-3">Organizer request rejected.</div>
  <% } %>

  <% if (error === 'notfound') { %>
    <div class="alert alert-danger py-2 mb-3">That organizer application could not be found.</div>
  <% } %>

  <% if (!applications.length) { %>
    <div class="card shadow-sm">
      <div class="card-body">
        <h2 class="h6 fw-semibold mb-2">No pending applications</h2>
        <p class="text-muted mb-0">Everything is reviewed right now. New organizer requests will show up here.</p>
      </div>
    </div>
  <% } %>

  <% applications.forEach(({ application, details }) => { %>
    <div class="card shadow-sm mb-3">
      <div class="card-body">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-3 mb-3">
          <div>
            <div class="fw-semibold"><%= application.organization || 'Organization not provided' %></div>
            <div class="text-muted small">
              <%= application.User?.name || 'Unknown user' %> · <%= application.User?.email || 'No email' %>
            </div>
          </div>
          <span class="badge bg-warning text-dark">Pending</span>
        </div>

        <div class="row g-3">
          <div class="col-12 col-lg-4">
            <div class="small text-uppercase text-muted mb-1">Role or title</div>
            <div><%= details.roleTitle || 'Not provided' %></div>
          </div>
          <div class="col-12 col-lg-4">
            <div class="small text-uppercase text-muted mb-1">Applied</div>
            <div><%= application.appliedAt ? new Date(application.appliedAt).toLocaleString() : 'Unknown time' %></div>
          </div>
          <div class="col-12 col-lg-4">
            <div class="small text-uppercase text-muted mb-1">Proof or contact</div>
            <div><%= details.proof || 'None provided' %></div>
          </div>
          <div class="col-12">
            <div class="small text-uppercase text-muted mb-1">Reason</div>
            <div><%= details.reason || 'No reason provided.' %></div>
          </div>
        </div>

        <div class="d-flex gap-2 flex-wrap mt-3">
          <form method="POST" action="/admin/organizers/<%= application.id %>/approve" class="m-0">
            <button type="submit" class="btn btn-success btn-sm">Approve</button>
          </form>
          <form method="POST" action="/admin/organizers/<%= application.id %>/reject" class="m-0">
            <button type="submit" class="btn btn-outline-danger btn-sm">Reject</button>
          </form>
        </div>
      </div>
    </div>
  <% }) %>
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Admin Dashboard — Campus Activity Hub</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="/assets/css/styles.css" rel="stylesheet">
</head>
<body>

<%- include('../partials/admin-nav', { page: 'dashboard' }) %>

<main class="container my-4">
  <h1 class="h5 fw-semibold mb-4">Admin Dashboard</h1>

  <div class="row g-3">
    <div class="col-12 col-md-4">
      <a href="/admin/verification-queue" class="text-decoration-none">
        <div class="card shadow-sm h-100">
          <div class="card-body">
            <div class="text-muted small">Pending applications</div>
            <div class="h3 fw-semibold mb-0"><%= pendingApplications %></div>
          </div>
        </div>
      </a>
    </div>
    <div class="col-12 col-md-4">
      <a href="/admin/moderation-queue" class="text-decoration-none">
        <div class="card shadow-sm h-100">
          <div class="card-body">
            <div class="text-muted small">Open reports</div>
            <div class="h3 fw-semibold mb-0"><%= openReports %></div>
          </div>
        </div>
      </a>
    </div>
    <div class="col-12 col-md-4">
      <a href="/admin/locations" class="text-decoration-none">
        <div class="card shadow-sm h-100">
          <div class="card-body">
            <div class="text-muted small">Total locations</div>
            <div class="h3 fw-semibold mb-0"><%= totalLocations %></div>
          </div>
        </div>
      </a>
    </div>
  </div>
</main>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
